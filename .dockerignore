# Keep the build context small — none of these belong in any image.
# .env: compose injects it at runtime (env_file); baking it into layers would freeze stale config
# and copy local secrets into the image.
.env
.git
.venv
site/
**/__pycache__/
.pytest_cache/
.ruff_cache/
.import_linter_cache/
.pyright/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
**/.terraform/
**/.terragrunt-cache/
**/.terragrunt-stack/
*.tfstate
*.tfstate.*
