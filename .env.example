# --- App ---
DEBUG=true
LOG_LEVEL=DEBUG

# --- Database (async Postgres / asyncpg) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ddd
DB_USER=ddd
DB_PASSWORD=ddd
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_ECHO=false

# --- Redis cache ---
CACHE_ENABLE=true
CACHE_NAMESPACES=users
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Rate limiting + request body size cap ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BODY_BYTES=1048576

# --- Keycloak (OIDC auth + RBAC) ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=ddd
KEYCLOAK_CLIENT_ID=ddd-api
# Optional: enforce the `aud` claim (Keycloak access tokens often carry aud=account).
KEYCLOAK_VERIFY_AUDIENCE=false

# --- CORS ---
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
