# --- App ---
# Host ports are OFFSET (+1) from the defaults so this stack can run alongside sibling projects
# (e.g. CJ-DJANGO-MVC) with no conflicts. docker-compose overrides these to the standard container
# ports for in-network traffic; the values here are for HOST-based runs (task api, ddd-seed).
DEBUG=true
LOG_LEVEL=DEBUG
API_PORT=8001

# --- Database (async Postgres / asyncpg) ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ddd
DB_USER=ddd
DB_PASSWORD=ddd
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=20
DB_ECHO=false

# --- Redis cache ---
CACHE_ENABLE=true
CACHE_NAMESPACES=users
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=

# --- Rate limiting + request body size cap ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BODY_BYTES=1048576

# --- Keycloak (OIDC auth + RBAC) ---
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=ddd
KEYCLOAK_CLIENT_ID=ddd-api
# Optional: enforce the `aud` claim (Keycloak access tokens often carry aud=account).
KEYCLOAK_VERIFY_AUDIENCE=false

# --- CORS ---
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
